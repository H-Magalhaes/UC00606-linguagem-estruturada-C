#include <stdio.h>
#include <string.h>

int main()
{
    char nome[15];
    char nome_cinco[50];
    int i;
    
    printf("Insira nome: ");
    fgets(nome, 15, stdin);
    //scanf("%s", &nome);
    
    for(i=0; i<5; i++){
        strcat(nome_cinco, nome);
    }
    printf("%s", nome_cinco);
    
    //for(i=0; i<5; i++){
    //    printf("%s", nome);
    //}

    return 0;
}
