float calculo(float fahrenheit, float celsius);

void mostrar_celsius(float fahrenheit, float celsius);

int main()
{
    float fahrenheit, celsius;
    
    printf("Insira graus em Fahrenheit: ");
    scanf("%f", &fahrenheit);
    
    celsius=calculo(fahrenheit, celsius);
    
    mostrar_celsius(fahrenheit, celsius);

    return 0;
}

float calculo(float fahrenheit, float celsius){
    
    celsius=(fahrenheit - 32) / 1.8;
    
    return celsius;
}

void mostrar_celsius(float fahrenheit, float celsius){
    
    printf("%.2f° Fahrenheit = %.2f° Celsius", fahrenheit, celsius);
}
