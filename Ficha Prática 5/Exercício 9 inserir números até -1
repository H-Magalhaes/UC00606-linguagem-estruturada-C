/******************************************************************************
9. Escreva um programa em C que solicite vários números ao utilizador até ser 
inserido o número -1. No final mostre qual dos números inseridos é o maior. 
*******************************************************************************/
#include <stdio.h>
#include <locale.h>

int main(){
    setlocale(LC_ALL,"Portuguese");{
        
        int i, idade=0, cont=0;
        float media=0, soma=0, maior=0;
        
    
     i=1;
    
    while(idade!=-1){
       
    printf("Insira %dª idade: ", i);
    scanf("%d", &idade);
    
        if(idade!=-1){
            cont++;
    
            soma+=idade;
        }
        if(i==1 && i!=-1){
            maior=idade;
        }
        else if(idade>maior){
            maior=idade;
        }
    
    i++;
    }
    printf("-1, Programa encerrado!\n");
    
    printf("A soma das idedes é %.2f\n", soma);
    media=(float)soma/cont;
    printf("A média da soma das idedes é %.2f\n", media);
    
    printf("A maior idade é: %.2f\n", maior);
    return 0;
}
}
