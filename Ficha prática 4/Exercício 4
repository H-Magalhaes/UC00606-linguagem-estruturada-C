/******************************************************************************
4. Elabore um programa em C, que peça 10 números e imprimir quantos são pares 
e quantos são ímpares. 
*******************************************************************************/
#include <stdio.h>
#include <locale.h>

int main(){
    setlocale(LC_ALL,"Portuguese");
    
    int idade, cont_par=0, i, cont_impar=0;

    
  for(i=1; i<=10; i++){
      printf("insira %dº número: ", i);
      scanf("%d", &idade);
      if(idade%2==0){
          cont_par=cont_par+1;
      }
      else{
           cont_impar=cont_impar+1;
      }
  }
  
  printf("Os pares são: %d", cont_par);
  printf("\nOs impares são: %d", cont_impar);
    
    

    return 0;
}
