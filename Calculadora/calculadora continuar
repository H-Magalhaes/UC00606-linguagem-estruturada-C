/******************************************************************************

Calculadora com opções números e deseja continuar

*******************************************************************************/
 #include <stdio.h>

    int main(){
        
    float num1, num2;
    int op;
    char ent;
    
    ent='s';
    while(ent=='s' || ent=='S'){
    
    printf("Insira primeiro número: ");
    scanf("%f", &num1);
    
    printf("Insira segundo número: ");
    scanf("%f", &num2);

    printf("-----Menu-----\n");
    printf("1 - Soma\n");
    printf("2 - Subtração\n");
    printf("3 - Multiplicação\n");
    printf("4 - Divisão\n");
    
    printf("Escola operação: ");
    scanf("%d", &op);
    
    switch(op){
        
        case 1:
        printf("A soma de %.2f e %.2f = %.2f", num1, num2, (num1 + num2));
        break;
        
        case 2:
        printf("A subtração de %.2f e %.2f = %.2f", num1, num2, (num1 - num2));
        break;
        
        case 3:
        printf("A multiplicação de %.2f e %.2f = %.2f", num1, num2, (num1 * num2));
        break;
        
        case 4:
        printf("A divisão de %.2f e %.2f = %.2f", num1, num2, (num1 / num2));
        break;
        
        default:
        printf("Errado");
    }
    
     printf("\nDeseja continuar? (s ou n) ");
     scanf("%s", &ent);
      }
      
     printf("Programa finalizado pelo operador");
    

    return 0;
    }
