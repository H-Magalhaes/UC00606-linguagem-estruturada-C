/******************************************************************************
8. Elabore um programa em C (alterando o exercício 1), que mostre os números
pares entre A e B, inclusive. Os valores de A e B devem ser definidos pelo
utilizador (A terá de ser inferior a B). 
*******************************************************************************/
#include <stdio.h>
#include <locale.h>

int main(){
    setlocale(LC_ALL,"Portuguese");
int num1, num2, aux, i;

    printf("Insíra primeiro número: ");
    scanf("%d", &num1);
    
    printf("Insíra segundo número: ");
    scanf("%d", &num2);
    
    if(num1>num2){
        aux=num1;
        num1=num2;
        num2=aux;
    }
    for(i=num1; i<=num2; i++){
        if(i%2==0){
            printf("%d\n", i);
        }
    }

    return 0;
}
