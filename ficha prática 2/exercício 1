/******************************************************************************

Elabore um programa em C que peça ao utilizador um número e verifique 
se o mesmo é par ou ímpar.Deverá escrever no ecrã “Par” no caso de ser 
“Par” ou “Impar”, no caso de ser “Ímpar”.

*******************************************************************************/
#include <stdio.h>

int main()
{
    int num1, num2;
    
    printf("Insira primeiro número: ");
    scanf("%d", &num1);
    
    printf("Insira segundo número: ");
    scanf("%d", &num2);
    
    if(num1>num2){
        printf("%d é maior que %d",num1,  num2);
    }
    else{
        printf("%d é maior que %d", num2, num1);
    }

    return 0;
}
