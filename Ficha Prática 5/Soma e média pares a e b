/******************************************************************************
3. Elabore um programa em C, que calcule e mostre a soma e a média dos números
pares entre a e b, inclusive. Os valores de a e de b serão pedidos 
ao utilizador. 
*******************************************************************************/
#include <stdio.h>
#include <locale.h>

int main(){
    setlocale(LC_ALL,"Portuguese");{
        
    int num1, num2, aux, a=0, cont=1, soma=0;
    float media=0.0;
    printf("Insira primeiro número: ");
    scanf("%d", &num1);
    
    printf("Insira segundo número: ");
    scanf("%d", &num2);
    
    if(num1>num2){
        aux=num1;
        num1=num2;
        num2=aux;
    }
    while(num1<=num2){
        
        if(num1%2==0){
            printf("%d\n", num1);
            cont++;
            soma+=num1;
        }
        num1++;
    }
    printf("A soma é: %d \n", soma);
    media=(float)soma/cont;
    printf("A média é: %.2f ", media);

    return 0;
}
}
