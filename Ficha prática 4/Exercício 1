/******************************************************************************
Elabore um programa em C, que mostre os números pares entre 1 e 100, 
inclusive.
*******************************************************************************/
#include <stdio.h>

int main(){
    int i, soma=0;
    
    for(i=1; i<=100; i++){
        if(i%2==0){
            printf("%d, ", i);
            soma+=i;
            
        }
    }
    printf("\nA soma é: %d", soma);

    return 0;
}
