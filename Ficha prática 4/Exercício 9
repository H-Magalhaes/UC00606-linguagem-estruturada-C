/******************************************************************************
9. Elabore um programa em C (alterando o exercício 2), que mostre a soma e a 
média dos números pares entre A e B, inclusive. Os valores de A e B devem ser 
definidos pelo utilizador (A terá de ser inferior a B).  
*******************************************************************************/
#include <stdio.h>
#include <locale.h>

int main(){
    setlocale(LC_ALL,"Portuguese");
int num1, num2, aux, i, soma=0, cont=0;
float media=0.0;

    printf("Insíra primeiro número: ");
    scanf("%d", &num1);
    
    printf("Insíra segundo número: ");
    scanf("%d", &num2);
    
    if(num1>num2){
        aux=num1;
        num1=num2;
        num2=aux;
    }
    for(i=num1; i<=num2; i++){
        if(i%2==0){
            printf("%d\n", i);
            cont++;
            soma+=i;
        }
    }
    media=soma/cont;
    printf("A soma dos pares é: %d\n", soma);
    printf("A média da soma dos pares é: %.2f", media);
    return 0;
}
