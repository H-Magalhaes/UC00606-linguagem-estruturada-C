/******************************************************************************
C não tem formato string. C vê como um vetor de caracteres.
No C uma string que termina com caracter nulo \0.

Ler uma string fornecida pelo utilizador "gets"
*******************************************************************************/
#include <stdio.h>
#include <stdlib.h>

int main()
{
    char nome[100] = "Pedro";
    
    printf("%s\n", nome);
    
    nome[4]='a';
    
    printf("%s\n", nome);
    
    nome[0]='H';
    
    printf("%s\n", nome);
    
    printf("Insira nome: ");
    gets(nome);
    
    //scanf("%s", nome);
    //fgets(nome, 20, stdin); // 1- variavel, 2-número de caracteres, 3- stdin entrada teclado
    
    printf("%s\n", nome);
    printf("A primeira letra é %c%c%c%c", nome[0], nome[3], nome[2], nome[3]);

    return 0;
}
