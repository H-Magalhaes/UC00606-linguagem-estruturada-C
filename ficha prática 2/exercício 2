/******************************************************************************

Elabore um programa em C que peça ao utilizador um número e verifique 
se o mesmo é par ou ímpar. Deverá escrever no ecrã “Par” no caso 
de ser “Par” ou “Impar”, no caso de ser “Ímpar”.

*******************************************************************************/
#include <stdio.h>

int main()
{
    int num;
    
    printf("Insira um número: ");
    scanf("%d", &num);
    
    if(num%2==0){
        printf("Par");
    }
    else{
        printf("Impar");
    }

    return 0;
}
