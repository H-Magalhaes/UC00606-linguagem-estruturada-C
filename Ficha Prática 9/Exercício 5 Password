/******************************************************************************
5. Escreva um programa que imprima no ecrã a palavra “verdadeiro” caso o 
utilizador acerte na password armazenada numa string, e escreva falso no 
caso contrário.
*******************************************************************************/
#include <stdio.h>
#include <string.h>

int main()
{
    char pass[12]="P@ssw0rd123";
    char pass_util[20];
    
    printf("Insira password: ");
    scanf("%s", &pass_util);
    
    if(strcmp(pass_util, pass)==0){
        printf("Verdadeiro");
    }else{
        printf("Falso");
    }

    return 0;
}
