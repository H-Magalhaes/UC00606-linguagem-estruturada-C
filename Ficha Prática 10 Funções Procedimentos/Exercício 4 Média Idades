/******************************************************************************
4. Elabore um programa em C, que peça várias idades ao utilizador e calcule a 
média das idades (a quantidade de idades será definida pelo utilizador).  
a) Sendo que o pedido da quantidade de idades deverá ser feito na função main. 
b) Os restantes pedidos e cálculos deverão ser feitos dentro de uma função 
e devolvidos. 
c) O resultado da média deverá ser mostrado através de um procedimento. 
*******************************************************************************/
#include <stdio.h>

float idades(int quant){
int idade, i;
float soma=0;

for(i=0; i<quant; i++){
    printf("Insira %dª idade: ", i+1);
    scanf("%d", &idade);
    
    soma=soma+idade;
}
return soma/quant;
}

void mostrar(float media){
    printf("A média de idades é de %.2f", media);
}


int main()
{
    int quant, idade;
    float media;
    
    printf("Quantas idades deseja inserir? ");
    scanf("%d", &quant);
    
    media = idades(quant);
    
    mostrar(media);

    return 0;
}
