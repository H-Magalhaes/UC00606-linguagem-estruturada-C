/******************************************************************************
6. Elabore um programa em C, que armazene 10 números num vetor inseridos pelo 
utilizador e mostre na tela os valores, mas na ordem inversa. 
*******************************************************************************/
#include <stdio.h>
#include <locale.h>

#define T_Max 10


int main()
{
    setlocale(LC_ALL, "Portuguese");

    
    int i;
    
    int v_num[T_Max];
    
    
    for(i=0; i<T_Max; i++){
        printf("Insira %dº número: ", i+1);
        scanf("%d", &v_num[i]);
    }
     for(i=T_Max-1; i>=0; i--){
        printf("%d,", v_num[i]);
    }

    return 0;

}
