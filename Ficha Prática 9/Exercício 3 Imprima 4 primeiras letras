#include <stdio.h>
#include <stdlib.h>
#include <string.h>

int main()
{
    char nome[15];
    char nome_quatro[4];
    int i;
    
    printf("Insira nome: ");
    fgets(nome, 15, stdin);
    
    for(i=0; i<4; i++){
        printf("%c\n", nome[i]);
    }
    
    printf("%c%c%c%c", nome[0], nome[1], nome[2], nome[3]);

    return 0;
}
