5. Elabore um programa em C, que peça 10 números e imprimir o maior e o menor. 
*******************************************************************************/
#include <stdio.h>
#include <locale.h>

int main(){
    setlocale(LC_ALL,"Portuguese");
    
    int num, maior=0, i, menor=0;

    
  for(i=1; i<=4; i++){
      printf("insira %dº número: ", i);
      scanf("%d", &num);
      
      if(i==1){
        menor=num;
        maior=num;
      }else if(num<menor){
        menor=num;
      }else if(num>maior){
        maior=num;
      }
  }
  printf("O número menor é %d\n", menor);
  printf("O número maior é %d", maior);
  
    return 0;
}
