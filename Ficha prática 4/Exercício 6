/******************************************************************************
Elabore um programa em C, que dado um número N (entre 1 e 10),
apresente a tabuada dos N.
*******************************************************************************/
#include <stdio.h>
#include <locale.h>

int main(){
    setlocale(LC_ALL,"Portuguese");
    
    int num, i;

    printf("Insira número: ");
    scanf("%d", &num);
    
    for(i=1; i<=10; i++){
        printf("%d x %d = %d\n", num, i, (num*i));
    }

    return 0;
}
