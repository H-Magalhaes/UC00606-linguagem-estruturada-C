/******************************************************************************
2. Elabore um programa em C, que calcule e mostre a soma e a média dos números
pares entre 1 e 100, inclusive.  
*******************************************************************************/
#include <stdio.h>

int main(){
    int i, soma=0, cont=0;
    float media;
    
    for(i=1; i<=100; i++){
        if(i%2==0){
            printf("%d, ", i);
            soma+=i;
            cont=cont+1;
            
        }
     
    }
    media = soma/(cont);
    printf("\nA soma dos números pares entre 1 e 100 é: %d", soma);
    printf("\nA média da soma dos números pares entre 1 e 100 é: %.2f", media);

    return 0;
}
